{
  "name": "react16-ssr-template",
  "version": "1.0.0",
  "description": "Template for react 16 ssr app",
  "repository": "https://github.com/dvo4253/react16-ssr.git",
  "scripts": {
    "predev": "rm -rf ./dist",
    "dev": "npm run lint && concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:analyze": "BUNDLE_ANALYZER=true npm run dev",
    "dev:server": "NODE_ENV=development BABEL_ENV=development nodemon src/server/index.js --exec babel-node",
    "dev:client": "NODE_ENV=development BABEL_ENV=development webpack-dev-server --config webpack/webpack.dev.babel.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "webpack --config webpack/webpack.prod.babel.js",
    "build:server": "webpack --config webpack/webpack.server.babel.js",
    "start": "node ./dist/server/index.js",
    "test": "npm run lint && jest --watch",
    "test:ci": "npm run lint && jest --coverage",
    "lint": "eslint --fix ./",
    "init": "source init.sh",
    "clean": "rm -rf node_modules && rm -f package-lock.json && rm -rf dist",
    "clean:install": "npm run clean && npm install && npm outdated"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "7.14.6",
    "@babel/preset-env": "7.14.5",
    "@babel/preset-react": "7.14.5",
    "assets-webpack-plugin": "7.1.0",
    "autoprefixer": "10.2.6",
    "axios": "0.21.1",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "10.1.0",
    "babel-loader": "8.2.2",
    "concurrently": "6.2.0",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.6",
    "eslint": "7.28.0",
    "express": "4.17.1",
    "express-winston": "4.1.0",
    "html-webpack-harddisk-plugin": "2.0.0",
    "html-webpack-plugin": "5.3.1",
    "html-webpack-pug-plugin": "3.0.0",
    "isomorphic-fetch": "3.0.0",
    "mini-css-extract-plugin": "1.6.0",
    "node-sass": "6.0.0",
    "optimize-css-assets-webpack-plugin": "6.0.0",
    "postcss-loader": "6.1.0",
    "prop-types": "15.7.2",
    "pug": "3.0.2",
    "ramda": "0.27.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-redux": "7.2.4",
    "redux": "4.1.0",
    "redux-observable": "1.2.0",
    "redux-thunk": "2.3.0",
    "rxjs": "7.1.0",
    "sass-loader": "12.1.0",
    "terser-webpack-plugin": "5.1.3",
    "webpack": "5.39.0",
    "webpack-disk-plugin": "0.0.2",
    "webpack-merge": "5.8.0",
    "webpack-node-externals": "3.0.0",
    "winston": "3.3.3",
    "write-assets-webpack-plugin": "1.0.5"
  },
  "devDependencies": {
    "@babel/node": "7.14.5",
    "css-loader": "5.2.6",
    "eslint-config-airbnb": "18.2.1",
    "eslint-plugin-babel": "5.3.1",
    "eslint-plugin-import": "2.23.4",
    "eslint-plugin-jsx-a11y": "6.4.1",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-promise": "5.1.0",
    "eslint-plugin-react": "7.24.0",
    "jest": "27.0.4",
    "nodemon": "2.0.7",
    "style-loader": "2.0.0",
    "supertest": "6.1.3",
    "wait-on": "5.3.0",
    "webpack-bundle-analyzer": "4.4.2",
    "webpack-cli": "4.7.2",
    "webpack-dev-server": "3.11.2"
  }
}
